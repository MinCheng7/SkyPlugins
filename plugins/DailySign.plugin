#!name= MinCheng7签到脚本
#!desc= 包含百度贴吧，巴哈姆特，华住会，什么值得买，携程旅行。在Loon中添加脚本订阅后，按需启用脚本。
#!author= MinCheng7
#!homepage= https://github.com/MinCheng7/SkyPlugins
#!icon= https://raw.githubusercontent.com/MinCheng7/icons/refs/heads/main/stickers/yj-good.png

[Script]

# 百度贴吧
cron "40 8 * * *" script-path=https://raw.githubusercontent.com/NobyDa/Script/master/BDTieBa-DailyBonus/TieBa.js, timeout=300, tag=百度贴吧签到@NobyDa

# 巴哈姆特
cron "0 8 * * *" script-path=https://raw.githubusercontent.com/NobyDa/Script/master/Bahamut/BahamutDailyBonus.js, timeout=300, tag=巴哈姆特签到@NobyDa

# 华住会
cron "0 7 * * *" script-path=https://raw.githubusercontent.com/MinCheng7/SkyPlugins/refs/heads/main/scripts/hzh.js, timeout=300, tag=华住会签到@Mincheng7

# 什么值得买
cron "15 8 * * *" script-path=https://raw.githubusercontent.com/MinCheng7/SkyPlugins/refs/heads/main/scripts/smzdm.js, timeout=300, tag=什么值得买签到@MinCheng7

# 携程旅行
cron "30 8 * * *" script-path=https://raw.githubusercontent.com/MinCheng7/SkyPlugins/refs/heads/main/scripts/ctrip.js, timeout=300, tag=携程旅行签到@MinCheng7
hostname = appgw.huazhu.com, hweb-mbf.huazhu.com, c.tieba.baidu.com, tiebac.baidu.com, api.kkmh.com, m.ctrip.com, m.bilibili.com, api.bilibili.com, app.bilibili.com, user-api.smzdm.com, *.smzdm.com
